# Copy this file to `.env` and fill in RUNNER_TOKEN.
# Get a token from:
#   https://github.com/<owner>/simplest-yocto-setup/settings/actions/runners/new
# Tokens are short-lived; if registration fails with an expired-token error,
# generate a new one.

RUNNER_URL=https://github.com/ruvi-d/simplest-yocto-setup
RUNNER_TOKEN=replace-me-with-token-from-repo-settings
RUNNER_NAME=yocto-runner-1
RUNNER_LABELS=self-hosted,Linux,X64,yocto-build
