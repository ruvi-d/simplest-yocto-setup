/*
 * Out-of-source OP-TEE device tree for the KISS Stompgoose board.
 *
 * Hardware-equivalent to the upstream STM32MP157A-DK1; the only
 * change versus stm32mp157a-dk1.dts is the model string, which lets
 * us verify the out-of-source DTS was actually consumed by the OP-TEE
 * build (look for it in the embedded DTB inside tee.elf / tee-pager).
 */

/dts-v1/;

#include "stm32mp157.dtsi"
#include "stm32mp15-pinctrl.dtsi"
#include "stm32mp15xxac-pinctrl.dtsi"
#include "stm32mp15xx-dkx.dtsi"

/ {
	model = "KISS Stompgoose (out-of-source OP-TEE DTS)";
	compatible = "st,stm32mp157a-dk1", "st,stm32mp157";

	aliases {
		ethernet0 = &ethernet0;
		serial0 = &uart4;
		serial1 = &usart3;
		serial2 = &uart7;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};
};

&bsec {
	board_id: board_id@ec {
		reg = <0xec 0x4>;
		st,non-secure-otp;
	};
	huk_otp: huk-otp@f0 {
		reg = <0xf0 0x10>;
	};
};
